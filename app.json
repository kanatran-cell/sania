{
  "expo": {
    "name": "SanIA",
    "slug": "sania",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "sania",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366F1"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SanIA necesita acceso a tu cámara para escanear productos alimenticios."
      }
    },
    "android": {
      "package": "com.sania.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366F1"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      ["expo-router", { "root": "./src/app" }],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "SanIA necesita acceso a tu cámara para escanear productos alimenticios."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "SanIA necesita acceso a tu cámara para escanear productos alimenticios."
        }
      ]
    ]
  }
}
